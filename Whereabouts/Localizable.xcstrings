    "ambiguousLocation.message %@ %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There are %2$lld locations named \"%1$@\". Which one did you mean?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "库里有 %2$lld 个叫「%1$@」的位置,你说的是哪一个?"
