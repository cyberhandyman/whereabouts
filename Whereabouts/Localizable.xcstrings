    "settings.ai.usage.footer.metric": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Metric calibration: tokens are read directly from each API response's usage field; counts match what the provider bills you. Buckets older than 90 days are auto-purged."
          }
