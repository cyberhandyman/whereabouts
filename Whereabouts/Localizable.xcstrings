    "settings.ai.volc.price.help": {
      "comment": "Phase 107: Footer hint explaining how volcengine pricing works.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional: fill in the actual price for your chosen model and the Usage section below will show a ¥ estimate row. Found on the Volcengine Ark console / model detail page. Leave both empty to show calls / tokens only."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选:填写所选 model 的实际单价后,下方「用量统计」会显示 ¥ 估算行。火山方舟控制台 / model 详情页能查到。两个都留空就只显示 calls / tokens,不算钱。"
          }
