              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld 样物品"
                }
              }
            }
          }
        }
      }
    },
    "status.summary.rooms %lld": {
      "comment": "Status bar: distinct top-level location count.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "in %lld room"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "in %lld rooms"
                }
              }
            }
          }
        },
        "zh-Hans": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "放在 %lld 个房间"
                }
              }
            }
          }
        }
      }
    },
    "tag.empty": {
      "comment": "Shown in tag picker when there are no tags yet.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No tags yet — add one below."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有标签 —— 在下面新建一个。"
          }
        }
      }
    },
    "tag.new.button": {
      "comment": "'Add' button next to new-tag input.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加"
          }
        }
      }
    },
    "tag.new.placeholder": {
      "comment": "New-tag input placeholder.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New tag name"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新标签名"
          }
        }
      }
    },
    "tag.preset.apparel": {
      "comment": "Phase 59 preset: clothing / shoes / bags.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apparel"
          }
        },
