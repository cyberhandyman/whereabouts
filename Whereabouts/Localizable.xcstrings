    "dup.alert.message.noLocation": {
      "comment": "Duplicate alert body when the new sentence didn't say a new location. %1$@ = existing item name, %2$@ = existing location path, %3$@ = comma-joined summary of new metadata. Step 1 TBD-8.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" is already at %2$@.\nYou didn't say where it is now — want to add %3$@ to it, or create a new one?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已有「%1$@」在 %2$@。\n这句话没说新位置 —— 是想给它补充信息(%3$@),还是另起一条?"
          }
        }
      }
    },
    "dup.alert.message.noLocation %@ %@ %@": {
      "comment": "Duplicate alert body when the new sentence didn't say a new location. %1$@ = existing item name, %2$@ = existing location path, %3$@ = comma-joined summary of new metadata. Step 1 TBD-8. [Phase 112 alias:代码用字符串插值查找时 key 带格式后缀,补一份同内容条目让两端都能命中。]",
      "localizations": {
