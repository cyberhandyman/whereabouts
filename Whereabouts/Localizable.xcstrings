    "settings.data.import.confirm.message.dedup": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "✓ Dedup is ON — items whose name + location matches an existing one will be skipped. Recommended."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "✓ 已开启「导入时跳过重复项目」—— 与本机现有物品 name + 位置完全相同的条目会被跳过。这是推荐设置。"
          }
        }
      }
    },
    "settings.data.import.confirm.message.noDedup": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Dedup is OFF — ALL items in the JSON will be appended, including duplicates of items you already have. Duplicates are hard to batch-delete afterwards (you'll need to find and remove each one manually). Consider turning Dedup on first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 已**关闭**「导入时跳过重复项目」—— JSON 里的所有条目都会被追加,**包括与你现有重复的物品**。重复项目之后**难以批量删除**(只能一条一条找出来手动删)。建议先打开去重再导入。"
          }
        }
      }
    },
    "settings.data.import.confirm.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import from JSON?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 JSON 文件导入?"
          }
        }
      }
    },
    "settings.data.import.dedup": {
      "comment": "Toggle: when importing JSON, drop entries whose name+path matches an existing item.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip duplicates on import"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入时跳过重复项目"
          }
        }
      }
    },
    "settings.data.import.dedup.hint": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Match is by name + full location path (case-sensitive). When OFF, repeated imports create duplicates that are hard to clean up — leave this ON unless you have a specific reason."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按「名字 + 完整位置路径」对比(大小写敏感)。**关掉之后再导入** = 重复物品堆积、之后批量删除困难。除非你有明确理由,建议保持开启。"
          }
        }
      }
    },
    "settings.data.import.footer": {
      "comment": "Settings: footer explanation under import button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads a JSON file exported earlier and appends all items at once. Duplicates are not auto-merged — clear data first if you want a clean restore."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取之前导出的 JSON,一次性把所有物品追加进库。不会自动去重 —— 想要干净还原请先清空数据。"
          }
        }
      }
    },
