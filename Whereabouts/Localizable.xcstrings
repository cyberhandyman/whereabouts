    "settings.icloud.footer.active": {
      "comment": "Phase 116 iCloud sync / iOS settings title / quotes.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data syncs to the private iCloud space of your Apple Account. Sign in with the same account on Mac and iPhone and everything stays in sync; the developer can never see it."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据会自动同步到你 Apple 账户的 iCloud 私有空间。Mac 和 iPhone 登录同一账户即可互通;开发者无法看到任何内容。"
          }
        }
      }
    },
    "settings.icloud.footer.inactive": {
      "comment": "Phase 116 iCloud sync / iOS settings title / quotes.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud could not be reached this launch (not signed in, or restricted network). Data is kept locally for now — sign in to iCloud and reopen the app to start syncing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本次启动未能连接 iCloud(未登录 iCloud 账户或网络受限),数据暂以本机模式保存,不影响使用。登录 iCloud 后重开 app 即自动同步。"
          }
        }
      }
    },
