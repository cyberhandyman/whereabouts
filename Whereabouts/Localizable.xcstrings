    "settings.ai.claude.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign up at https://console.anthropic.com/ → API Keys to create a key starting with sk-ant-.\nEndpoint defaults to the official Anthropic URL — change to your proxy/relay URL if you use one.\n⚠️ Key is stored as **plain text** in the prefs plist (a deliberate trade-off for single-user ad-hoc-signed dev builds — Keychain would prompt on every rebuild)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "到 https://console.anthropic.com/ 注册 → API Keys 生成 sk-ant-... 开头的 key。\nEndpoint 默认是 Anthropic 官方,如果你用第三方中转站(例:某些代理服务),改成它给你的 URL。\n⚠️ Key 以**明文**保存在偏好设置 plist 里(单 Mac 个人 dev 版的取舍 —— 避免每出 build 都弹钥匙串授权框)。"
          }
        }
      }
    },
