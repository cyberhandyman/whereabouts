    "settings.data.export.confirm.message %@": {},
    "settings.data.export.confirm.message %lld": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld items will be exported to JSON, including names, locations, tags, photos (base64-encoded), purchase metadata, location history, and lent-out state. No API keys or personal credentials are included. The file can be re-imported later."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将以 JSON 格式导出全部 %lld 件物品,包含名字、位置、标签、照片(base64 编码)、购买元数据、位置历史、借出状态。**不包含** API key 等敏感信息。文件可以稍后再导入回来。"
          }
        }
      }
    },
    "settings.data.export.confirm.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export all items?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出所有物品?"
          }
        }
      }
    },
    "settings.data.export.footer": {
      "comment": "Settings: footer explanation under export button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exports all (non-deleted) items into a single JSON file. Photos are embedded as base64. Use this for backup or to move to another Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把所有未删除的物品打包成一个 JSON 文件(照片以 base64 内嵌)。用于备份或迁移到另一台 Mac。"
          }
        }
      }
    },
