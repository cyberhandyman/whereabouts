        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已有「%1$@」在 %2$@。\n这句话没说新位置 —— 是想给它补充信息(%3$@),还是另起一条?"
          }
        }
      }
    },
    "dup.alert.message.withLocation": {
      "comment": "Duplicate alert body when both an existing and a new location exist. %1$@ = existing name, %2$@ = existing path, %3$@ = new name, %4$@ = new path. Step 1 TBD-9.",
