    "input.aiToggle.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When checked, each entry runs the local parser first (instant save), then a background AI re-parse refines the fields — each row shows ✨ Processing on the right while running. Adds 1-3 s per entry, much more accurate for tricky names."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "勾上后,录入会先走本地解析存条目,再后台调 AI 重新拆字段 —— 处理时该项右侧会显示 ✨ 正在理解。每次录入会多花 1-3 秒,但对怪命名的物品准确率高很多。"
          }
        }
      }
    },
    "input.aiToggle.label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
