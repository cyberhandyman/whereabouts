    "settings.backup.footer": {
      "comment": "Phase 117.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two channels: ① live sync — changes flow between your devices via iCloud automatically; ② manual sync — immediately pulls the data file other devices wrote to iCloud Drive, merges with de-duplication, and writes this device's latest data back (the file lives in iCloud Drive/Whereabouts)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "两条通道:① 实时同步 —— 改动自动经 iCloud 在你的设备间流动;② 手动同步 —— 立即拉取 iCloud 云盘里其它设备写入的数据文件、合并去重,并把本机最新数据写回去(文件在 iCloud 云盘/Whereabouts/,「文件」app 和访达都能看到)。"
          }
        }
      }
    },
